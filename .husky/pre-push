#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────
# pre-push hook – Acte Monorepo
# Runs lint and type-check before allowing a push.
# Formatting is checked in CI, not here.
# ─────────────────────────────────────────────────────────

set -euo pipefail

echo "━━━ pre-push: Running lint… ━━━"
bun run lint

echo "━━━ pre-push: Running typecheck… ━━━"
bun run check-types

echo "━━━ Pre-push: All checks passed ✅ ━━━"
