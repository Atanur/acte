{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun run src/index.ts",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.6.0",
    "@scalar/hono-api-reference": "^0.11.3",
    "better-auth": "^1.2.0",
    "db": "workspace:*",
    "email": "workspace:*",
    "expo-server-sdk": "^6.1.0",
    "hono": "^4.7.0",
    "jobs": "workspace:*",
    "shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
